  "test_cases": [
    {
      "id": "TC_SCH_020_DELETE_ScheduleJob_CascadeCleansSchedule",
      "use_case_ref": "UC_001 + UC_004",
      "module": "schedule",
      "layer": "regression",
      "file_target": "tests/api/regression/schedule/schedule-advanced.regression.spec.js",
      "action": "append",
      "method": "DELETE",
      "path": "/api/live-stream/:liveId/schedule-job/:jobId",
      "setup": [
        "createLiveStream → cleaner.register('live-stream', id)",
        "createScheduleJob(stream) → job",
        "GET /api/live-stream/:liveId/schedule → poll max 3x/500ms until schedule list non-empty, capture schedId"
      ],
      "steps": [
        "DELETE /api/live-stream/:liveId/schedule-job/:jobId",
        "Assert response status 200 or 204",
        "GET /api/live-stream/:liveId/schedule → poll max 3x/500ms",
        "Assert schedule list empty (length === 0)"
      ],
      "expected_status": [200, 204],
      "expected_body": null,
      "post_assertions": [
        "GET /api/live-stream/:liveId/schedule → body.data array length === 0"
      ],
      "requires_cleanup": true,
      "cleanup_note": "live-stream cleanup sufficient — job and schedule should be gone by fix",
      "zod_validation": false,
      "schema_ref": null,
      "tags": ["@critical"],
      "notes": "Core regression para issue-8083. Si cascade es async, el poll post-delete puede tomar hasta 3x500ms. Si schedule persiste tras 1500ms, test falla — comportamiento pre-fix exacto."
    },
