# Configuración de la API
BASE_URL=https://dev.platform.mediastre.am
API_TOKEN=<tu-api-token>

# Configuración de VMS (Video Management Service)
VMS_BASE_URL=https://dev.vms.platform.mediastre.am
VMS_TOKEN=<vms-api-token>

# Configuración opcional
# ACCOUNT_ID=
# RESTRICTED_USER_ID=
# SLACK_WEBHOOK_URL=
# TIMEOUT=30000
# DEBUG=false

# ========================================
# Pipeline Multi-Agente
# ========================================
# El Agente 1 (agent1-watch) no requiere variables de entorno.
# El diff se provee manualmente en pipeline/input/diff.patch

# ========================================
# Configuración Embed SM2 (tests/embed/)
# ========================================
EMBED_HOST=dev.mdstrm.com
EMBED_PROTOCOL=https

# IDs de prueba para Embed
EMBED_MEDIA_ID=<media-id-24-hex>
EMBED_LIVE_STREAM_ID=<live-stream-id-24-hex>
EMBED_PLAYLIST_ID=<playlist-id-24-hex>
EMBED_ACCOUNT_ID=<account-id-24-hex>
EMBED_CATEGORY_ID=<category-id-24-hex>
EMBED_PLAYER_ID=<player-id-24-hex>
EMBED_SCHEDULE_JOB_LIVE_ID=<schedule-job-live-id-24-hex>
EMBED_SCHEDULE_JOB_VOD_ID=<schedule-job-vod-id-24-hex>

# Tokens para Embed (opcionales)
# EMBED_ADMIN_TOKEN=<admin-token>
# EMBED_ACC_TOKEN=<acc-token>
# EMBED_ACCESS_TOKEN=<access-token>

# Assets de prueba
# EMBED_TEST_POSTER_URL=https://via.placeholder.com/1280x720
